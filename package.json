{
  "name": "gyumolcsnaptar",
  "private": true,
  "version": "3.0.6",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:desktop:web": "tsc -b && vite build --mode desktop",
    "build:desktop": "npm run build:desktop:web && electron-packager . Gyumolcsnaptar --platform=win32 --arch=x64 --out=release --overwrite --ignore=\"^/(src|supabase|node_modules/.cache|release)/\"",
    "infra:up": "docker compose -f keycloak/docker-compose.yml up -d",
    "infra:down": "docker compose -f keycloak/docker-compose.yml down",
    "infra:logs": "docker compose -f keycloak/docker-compose.yml logs -f keycloak cloudflared",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.0",
    "date-holidays": "^3.27.0",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "keycloak-js": "^26.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^37.7.1",
    "electron-builder": "^26.0.12",
    "electron-packager": "^17.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9"
  }
}
